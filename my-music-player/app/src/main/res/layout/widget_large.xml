<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121318"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/widget_album_art"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="#1C1E24"
                android:src="@android:drawable/ic_media_play"
                android:contentDescription="Album Art"
                android:padding="12dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_song_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="My Music Player"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_song_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select a song to start"
                    android:textColor="#A0A5B5"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Previous Song"
                android:scaleType="fitCenter"
                android:layout_marginEnd="16dp" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:contentDescription="Play or Pause"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="Next Song"
                android:scaleType="fitCenter"
                android:layout_marginStart="16dp" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
